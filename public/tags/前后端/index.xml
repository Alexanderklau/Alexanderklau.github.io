      <link>http://localhost:1313/posts/golang%E8%B0%83%E7%94%A8rabbitmq%E6%B6%88%E6%81%AF%E9%98%9F%E5%88%97%E5%92%8C%E5%B0%81%E8%A3%85/</link>
      <pubDate>Mon, 13 Apr 2020 10:11:00 +0000</pubDate>
